{
  "name": "danmaku-rainbow",
  "version": "1.0.0",
  "author": "Tissue",
  "private": true,
  "type": "module",
  "description": "macOS Bilibili live danmaku overlay for OBS",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "npm run build:web && electron .",
    "dev:web": "vite --host 127.0.0.1",
    "build:web": "vite build",
    "build": "npm run build:web && electron-builder --mac dir",
    "dist": "npm run build:web && electron-builder --mac zip",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "tiny-bilibili-ws": "1.0.2",
    "vite": "8.0.13",
    "ws": "8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "electron": "41.0.2",
    "electron-builder": "26.0.12",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.codex.danmaku-rainbow",
    "productName": "彩虹弹幕机",
    "asar": true,
    "files": [
      "dist-web/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.png",
      "target": ["dir", "zip"],
      "identity": null,
      "artifactName": "彩虹弹幕机-${version}-${arch}.${ext}"
    }
  }
}
